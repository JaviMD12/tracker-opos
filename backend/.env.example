STRIPE_SECRET_KEY=sk_test_tu_clave_aqui
GEMINI_API_KEY=tu_clave_de_gemini_aqui
SECRET_KEY=genera_una_clave_aleatoria_larga_aqui

# Login con Google (Google Cloud Console -> APIs y servicios -> Credenciales
# -> ID de cliente de OAuth 2.0 -> tipo "Aplicacion web". Origen autorizado:
# http://localhost:8000 ; URI de redireccion autorizado:
# http://localhost:8000/api/auth/google/callback)
GOOGLE_CLIENT_ID=tu_client_id_de_google_aqui
GOOGLE_CLIENT_SECRET=tu_client_secret_de_google_aqui

# URL de un webhook propio (Zapier, Make, n8n, tu propio backend de email...)
# que reciba {"email": ..., "link": ...} y se encargue de enviar el correo de
# recuperacion de contraseña. Si se deja vacio, /api/auth/olvido-password
# sigue respondiendo con el mensaje generico pero no envia nada.
WEBHOOK_RECUPERACION_URL=https://tu-webhook-de-recuperacion.example.com
